{
  "name": "web-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:terminal": "bun run src/build-terminal.ts",
    "dev": "bun run build:terminal && bun --hot src/index.ts",
    "build": "bun run build:terminal && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify",
    "start": "NODE_ENV=production bun src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "webtuigui": "file:../../GUI/WebTUIGUI"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
