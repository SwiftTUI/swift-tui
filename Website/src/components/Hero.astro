---
import DemoTerminal from "./DemoTerminal.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<section class="hero">
  <div class="shell">
    <div class="copy">
      <span class="tag reveal" style="--i:0">
        <span class="dot"></span>
        <span>live demo · running below this line</span>
      </span>

      <h1 class="reveal" style="--i:1">
        SwiftUI semantics,<br/>
        drawn in <span class="accent">terminal cells</span>.
      </h1>

      <p class="lead reveal" style="--i:2">
        A Swift package that lowers SwiftUI-shaped views through a strict
        seven-phase pipeline — no global solver, no virtual DOM, no
        <span class="mono">curses</span>. One <span class="mono">App</span>
        declaration runs as a terminal binary, in the browser via WASI,
        or embedded inside a SwiftUI window or a DOM element.
      </p>
      <code class="lead-pipeline mono reveal" style="--i:2">
        resolve <span class="arr">→</span> measure <span class="arr">→</span> place <span class="arr">→</span> semantics <span class="arr">→</span> draw <span class="arr">→</span> raster <span class="arr">→</span> <em>commit</em>
      </code>

      <div class="actions reveal" style="--i:3">
        <a class="cta cta--primary" href="#demo">
          <span>Run the demo</span>
          <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="cta" href={`${base}/docs/documentation/swifttui/`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" aria-hidden="true"><path d="M4 4h12l4 4v12H4z"/><path d="M16 4v4h4"/></svg>
          <span>Read the DocC</span>
        </a>
        <a class="cta" href="https://github.com/GoodHatsLLC/SwiftTUI" rel="noreferrer noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-.99-.02-1.94-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.97 10.97 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.15 0 1.55-.01 2.81-.01 3.19 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
          <span>Source</span>
        </a>
      </div>

      <div class="install reveal" style="--i:4" role="region" aria-label="installation">
        <div class="install-head mono">
          <span class="prompt">Package.swift</span>
          <span class="sep">·</span>
          <span class="ver">swift-tools-version: 6.3</span>
          <span class="sep">·</span>
          <a class="ver-link" href="#quickstart">quickstart →</a>
        </div>
        <pre class="install-body mono"><code><span class="cm">// add to dependencies</span>
.package(url: <span class="s">"https://github.com/GoodHatsLLC/SwiftTUI"</span>, branch: <span class="s">"main"</span>)

<span class="cm">// add to your executable target</span>
.product(name: <span class="s">"SwiftTUI"</span>,    package: <span class="s">"SwiftTUI"</span>)
.product(name: <span class="s">"SwiftTUICLI"</span>, package: <span class="s">"SwiftTUI"</span>)</code></pre>
      </div>

      <ul class="meta reveal mono" style="--i:5">
        <li><span class="k">requires</span><span class="v">Swift 6.3 · macOS 15 · iOS 18 · Linux · Android (in tree)</span></li>
        <li><span class="k">runs in</span><span class="v">terminal · browser via WASI · SwiftUI · any DOM element</span></li>
        <li><span class="k">strict</span><span class="v">Swift 6 · <em>@MainActor</em>-isolated · memory-safe · existential-any</span></li>
        <li><span class="k">deferred</span><span class="v"><em>NavigationStack</em> · richer accessibility modeling</span></li>
      </ul>
    </div>

    <aside class="stage">
      <DemoTerminal id="demo" />
    </aside>
  </div>
</section>

<style>
  .hero {
    padding: 72px 0 28px;
  }
  .shell {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 56px;
    align-items: start;
  }
  .copy { padding-top: 8px; }
  h1 .accent { color: var(--accent); }
  p.lead {
    margin-top: 22px;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 56ch;
    letter-spacing: -0.005em;
  }
  .lead-pipeline {
    display: block;
    margin-top: 14px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-left: 2px solid var(--accent);
    background: var(--panel);
    border-radius: 0 6px 6px 0;
    font-size: 11.5px;
    color: var(--ink-2);
    letter-spacing: 0.02em;
    word-break: break-word;
    line-height: 1.7;
    max-width: 56ch;
  }
  .lead-pipeline em { font-style: normal; color: var(--accent); }
  .lead-pipeline .arr { color: var(--ink-4); padding: 0 2px; }
  .tag { margin-bottom: 28px; }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .install {
    margin-top: 36px;
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    overflow: hidden;
    background: var(--panel);
  }
  .install-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--line);
    font-size: 11.5px;
    color: var(--ink-3);
    background: var(--panel-2);
  }
  .install-head .prompt { color: var(--ink-2); }
  .install-head .sep { color: var(--ink-4); }
  .install-head .ver { color: var(--ink-3); }
  .install-body {
    margin: 0;
    padding: 16px 14px;
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink);
    overflow-x: auto;
  }
  .install-body .s { color: var(--accent); }
  .install-body .cm { color: var(--ink-4); font-style: italic; }
  .install-head .ver-link {
    color: var(--accent);
    margin-left: auto;
    transition: color 160ms ease;
  }
  .install-head .ver-link:hover { color: #2dd4a3; }

  .meta {
    list-style: none;
    padding: 0;
    margin: 28px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-3);
  }
  .meta li { display: grid; grid-template-columns: 90px 1fr; gap: 14px; }
  .meta .k { color: var(--ink-4); letter-spacing: 0.06em; text-transform: uppercase; font-size: 10.5px; padding-top: 2px; }
  .meta .v { color: var(--ink-3); }
  .meta em { font-style: normal; color: var(--ink-2); }

  .stage {
    position: sticky;
    top: 84px;
  }

  @media (max-width: 1080px) {
    .shell { grid-template-columns: 1fr; gap: 44px; }
    .stage { position: static; }
  }
  @media (max-width: 720px) {
    .hero { padding: 44px 0 18px; }
    p.lead { font-size: 16px; }
    .meta li { grid-template-columns: 90px 1fr; gap: 8px; }
  }
</style>
