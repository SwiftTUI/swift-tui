---
const phases = [
  {
    n: "01",
    name: "resolve",
    one: "Authored views collapse into the resolved tree.",
    sym: "Resolver · ResolvedNode",
  },
  {
    n: "02",
    name: "measure",
    one: "Parents propose sizes, children choose.",
    sym: "ProposedSize · ChosenSize",
  },
  {
    n: "03",
    name: "place",
    one: "Recursive layout assigns integer-cell rects.",
    sym: "PlacementPlan",
  },
  {
    n: "04",
    name: "semantics",
    one: "Focus chain, accessibility, identity rolls up.",
    sym: "SemanticTree",
  },
  {
    n: "05",
    name: "draw",
    one: "Per-cell glyphs and styles emit as commands.",
    sym: "DrawCommand",
  },
  {
    n: "06",
    name: "raster",
    one: "Commands rasterize into a capability-aware surface.",
    sym: "RasterSurface",
  },
  {
    n: "07",
    name: "commit",
    one: "Diff against last frame and stream ANSI/OSC.",
    sym: "CommitPlan",
  },
];
---
<section class="pipeline" id="pipeline">
  <div class="shell">
    <header class="head">
      <span class="eyebrow"><span class="num">/01</span>Frame pipeline</header>
      <h2>Seven phases. Strict order. No collapsing.</h2>
      <p class="lede">
        Layout is recursive parent-child negotiation, not a global solver.
        State drives rendering, not the reverse. The phase order is enforced
        by <span class="mono">DefaultRenderer</span>, <span class="mono">FrameArtifacts</span>,
        and the regression suites.
      </p>
    </header>

    <ol class="strip mono" aria-label="frame phases">
      {phases.map((p, idx) => (
        <li class="phase reveal" style={`--i:${idx + 1}`}>
          <div class="row top">
            <span class="ix">{p.n}</span>
            <span class={`pill ${idx === 6 ? "pill--commit" : ""}`}>{p.name}</span>
          </div>
          <p class="one">{p.one}</p>
          <div class="sym">{p.sym}</div>
          {idx < phases.length - 1 && (
            <svg class="arrow" width="22" height="10" viewBox="0 0 22 10" aria-hidden="true">
              <path d="M0 5h18M14 1l4 4-4 4" stroke="currentColor" fill="none" stroke-width="1" stroke-linecap="square" />
            </svg>
          )}
        </li>
      ))}
    </ol>

    <div class="rail">
      <div class="rail-track">
        <span class="ticker">resolve · measure · place · semantics · draw · raster · commit · </span>
        <span class="ticker" aria-hidden="true">resolve · measure · place · semantics · draw · raster · commit · </span>
      </div>
    </div>
  </div>
</section>

<style>
  .pipeline { padding: 96px 0 56px; border-top: 1px solid var(--line); margin-top: 64px; }
  .head { max-width: 760px; margin-bottom: 56px; }
  .head h2 { margin-top: 16px; }
  .head .lede { margin-top: 18px; max-width: 70ch; }

  .strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .phase {
    position: relative;
    padding: 26px 18px 22px;
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    min-height: 178px;
  }
  .phase:last-child { border-right: 0; }
  .phase .row { display: flex; align-items: center; gap: 10px; }
  .ix {
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.06em;
  }
  .pill {
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    color: var(--ink);
    font-size: 11.5px;
    background: var(--panel-2);
    letter-spacing: 0.02em;
  }
  .pill--commit {
    color: var(--accent);
    border-color: rgba(52, 211, 153, 0.45);
    background: var(--accent-soft);
  }
  .one {
    margin-top: 14px;
    color: var(--ink-2);
    font-size: 13px;
    font-family: var(--font-sans);
    letter-spacing: -0.005em;
    line-height: 1.5;
  }
  .sym {
    margin-top: auto;
    padding-top: 18px;
    color: var(--ink-3);
    font-size: 11px;
    letter-spacing: 0.02em;
    border-top: 1px dashed var(--line);
  }
  .arrow {
    position: absolute;
    right: -11px;
    top: 36px;
    color: var(--ink-4);
    z-index: 1;
    background: var(--bg);
    padding: 2px 0;
  }

  .rail {
    margin-top: 36px;
    overflow: hidden;
    height: 28px;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
  }
  .rail-track {
    display: inline-flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 38s linear infinite;
    will-change: transform;
  }
  .ticker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--ink-4);
    text-transform: uppercase;
    padding-right: 22px;
  }
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 1080px) {
    .strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .phase:nth-child(2n) { border-right: 0; }
    .phase { border-bottom: 1px solid var(--line); }
    .arrow { display: none; }
  }
  @media (max-width: 540px) {
    .strip { grid-template-columns: 1fr; }
    .phase { border-right: 0; }
  }
</style>
