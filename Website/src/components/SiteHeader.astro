---
import Mark from "./Mark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = `${base}/`;
---
<header class="site-header">
  <div class="shell row">
    <a class="brand" href={home}>
      <Mark size={22} />
      <span class="wordmark">SwiftTUI</span>
      <span class="version mono">v0.0.1</span>
    </a>

    <nav class="nav mono" aria-label="primary">
      <a href={`${home}#demo`}>Demo</a>
      <a href={`${home}#why`}>Why</a>
      <a href={`${base}/pipeline/`}>Pipeline</a>
      <a href={`${home}#runtimes`}>Runtimes</a>
      <a href={`${home}#surface`}>Surface</a>
      <a href={`${home}#quickstart`}>Quickstart</a>
      <a href={`${base}/docs/documentation/swifttui/`}>Docs</a>
    </nav>

    <div class="actions">
      <a class="ghost mono" href="https://github.com/GoodHatsLLC/SwiftTUI" rel="noreferrer noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-.99-.02-1.94-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.97 10.97 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.15 0 1.55-.01 2.81-.01 3.19 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
  <div class="hairline"></div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
  }
  .row {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 60px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .wordmark {
    font-size: 14.5px;
  }
  .version {
    font-size: 11px;
    padding: 2px 7px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    color: var(--ink-3);
    margin-left: 2px;
  }
  .nav {
    display: flex;
    gap: 18px;
    margin-left: auto;
    margin-right: auto;
    color: var(--ink-2);
    font-size: 12.5px;
  }
  .nav a {
    transition: color 160ms ease;
    white-space: nowrap;
  }
  .nav a:hover { color: var(--ink); }
  @media (max-width: 1080px) {
    .nav { gap: 14px; font-size: 12px; }
  }
  .actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .ghost {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 11px;
    border-radius: 7px;
    border: 1px solid var(--line-strong);
    color: var(--ink-2);
    font-size: 12px;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
  }
  .ghost:hover { color: var(--ink); border-color: var(--line-warm); background: var(--panel-2); }
  .hairline { height: 1px; background: var(--line); }
  @media (max-width: 820px) {
    .row { gap: 12px; }
    /* keep section anchors reachable on mobile via a horizontal scroll row */
    .nav {
      gap: 16px;
      font-size: 11.5px;
      margin: 0 0 0 4px;
      padding: 0 4px;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      mask-image: linear-gradient(to right, transparent 0, #000 6%, #000 94%, transparent 100%);
              -webkit-mask-image: linear-gradient(to right, transparent 0, #000 6%, #000 94%, transparent 100%);
    }
    .nav::-webkit-scrollbar { display: none; }
  }
  @media (max-width: 480px) {
    .version { display: none; }
    .ghost span { display: none; }
    .ghost { padding: 7px 9px; }
  }
</style>
