---
interface Props {
  pageKey?: string;
}
const { pageKey } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const navItems: ReadonlyArray<{ href: string; label: string; key: string }> = [
  { href: `${base}/principles`, label: "Principles", key: "principles" },
  { href: `${base}/start`, label: "Start", key: "start" },
  { href: `${base}/learn`, label: "Learn", key: "learn" },
  { href: `${base}/design`, label: "Design", key: "design" },
  { href: `${base}/contribute`, label: "Contribute", key: "contribute" },
  { href: `${base}/api`, label: "API", key: "api" },
];
---

<header class="site-header">
  <a class="brand" href={`${base}/`} aria-label="TerminalUI home">
    <span class="brand-dot" aria-hidden="true"></span>
    <span class="brand-mark">TerminalUI</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          aria-current={pageKey === item.key ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <a
    class="header-cta"
    href="https://github.com/GoodHatsLLC/swift-terminal-ui"
    target="_blank"
    rel="noreferrer"
  >
    GitHub
  </a>
</header>
