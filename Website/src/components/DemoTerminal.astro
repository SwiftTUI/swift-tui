---
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const iframeSrc = `${base}/webexample/`;
const isDev = import.meta.env.DEV;
const localWebExampleIndexPath = fileURLToPath(
  new URL("../../../Examples/WebExample/pages-dist/index.html", import.meta.url)
);
const localWebExampleWasmPath = fileURLToPath(
  new URL(
    "../../../Examples/WebExample/pages-dist/TerminalApp/dist/assets/app.wasm",
    import.meta.url
  )
);
const hasLocalWebExampleArtifact = existsSync(localWebExampleIndexPath)
  && existsSync(localWebExampleWasmPath);
const showDevStub = isDev && !hasLocalWebExampleArtifact;

interface Props {
  /** display height in px on lg+ viewports */
  height?: number;
  /** anchor id */
  id?: string;
  /** label override */
  title?: string;
}
const { height = 560, id = "demo", title = "WebExample.wasm" } = Astro.props;
---
<section class="demo" id={id}>
  <div class="frame" style={`--demo-h:${height}px`}>
    <div class="bar">
      <div class="dots" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <div class="title mono">
        <span class="origin">swifttui.io</span>
        <span class="sep">·</span>
        <span>{title}</span>
      </div>
      <div class="caps mono" aria-label="terminal capabilities">
        <span class="cap">UNICODE</span>
        <span class="cap">TRUECOLOR</span>
        <span class="cap">SAB-STDIN</span>
        <span class="cap on">LIVE</span>
      </div>
    </div>

    <div class="surface">
      {showDevStub ? (
        <div class="dev-stub mono" aria-hidden="true">
          <div class="ds-frame">
            <div class="ds-row"><span class="ds-prompt">›</span><span>swift build --swift-sdk swift-6.3.1-RELEASE_wasm</span></div>
            <div class="ds-row dim"><span>     </span><span>building Examples/WebExample/TerminalApp ...</span></div>
            <div class="ds-row dim"><span>     </span><span>brotli q=9 → app.wasm (4.2&thinsp;MiB → 1.3&thinsp;MiB)</span></div>
            <div class="ds-row"><span class="ds-prompt">›</span><span>bun run --cwd Website build:wasm:dev</span></div>
            <div class="ds-row dim"><span>     </span><span>artifact ready at <em>/webexample/</em>, awaiting Pages composition</span></div>
            <div class="ds-row warn">
              <span class="ds-prompt">!</span>
              <span>local dev: WASM artifact not mounted at this origin</span>
            </div>
            <div class="ds-row dim"><span>     </span><span>production composition in <em>.github/workflows/cloudflare-pages.yml</em></span></div>
            <div class="ds-row"><span class="ds-prompt">›</span><span class="caret-block">_</span></div>
          </div>
          <div class="ds-foot">
            <span>Run <span class="ds-mark">bun run build:wasm:dev</span> in <span class="ds-mark">Website/</span> to compose the demo locally.</span>
          </div>
        </div>
      ) : (
        <iframe
          src={iframeSrc}
          title="SwiftTUI WebExample"
          loading="eager"
          referrerpolicy="same-origin"
        ></iframe>
      )}
      <div class="grid" aria-hidden="true"></div>
      <div class="scan" aria-hidden="true"></div>
    </div>

    <div class="status mono">
      <div class="left">
        <span class="caret">›</span>
        <span class="path">target/wasm32-wasi</span>
        <span class="sep">·</span>
        <span class="phase">runtime: <em>WebHost</em></span>
      </div>
      <div class="mid">
        <span class="phaseRing">resolve</span>
        <span class="phaseRing">measure</span>
        <span class="phaseRing">place</span>
        <span class="phaseRing">semantics</span>
        <span class="phaseRing">draw</span>
        <span class="phaseRing">raster</span>
        <span class="phaseRing on">commit</span>
      </div>
      <div class="right">
        <span class="kbd-row" aria-label="navigation hints">
          <span class="kbd">tab</span><span class="dim">focus</span>
          <span class="kbd">↑↓</span><span class="dim">scroll</span>
          <span class="kbd">⏎</span><span class="dim">activate</span>
        </span>
      </div>
    </div>
  </div>

  <p class="caption">
    The frame above is Conway's Game of Life, written as a single SwiftTUI
    <span class="mono">View</span>, compiled to <span class="mono">wasm32-wasi</span>,
    and mounted via <span class="mono">GUI/WebHost</span>. Tap a cell to flip
    it; click-and-drag to paint a stroke. The zoom picker switches between
    braille (8&times; density), half-block (2&times;), and square (1&times;)
    rendering — same authoring code, three glyph strategies. No terminal
    emulator. No xterm.js. No emulator shim.
  </p>
</section>

<style>
  .demo { padding-top: 6px; }
  .frame {
    position: relative;
    border: 1px solid var(--line-strong);
    border-radius: 14px;
    background: linear-gradient(180deg, #0c0c0c 0%, #0a0a0a 100%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 24px 64px -28px rgba(0, 0, 0, 0.65),
      0 0 0 1px rgba(0, 0, 0, 0.6);
    overflow: hidden;
  }
  .bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 38px;
    padding: 0 14px;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255,255,255,0.025) 0%, transparent 100%);
  }
  .dots { display: flex; gap: 7px; align-items: center; }
  .dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #1f1f1f;
    border: 1px solid rgba(255, 255, 255, 0.04);
  }
  .dots span:nth-child(1) { background: #ff5f56; border-color: rgba(0,0,0,0.2); }
  .dots span:nth-child(2) { background: #ffbd2e; border-color: rgba(0,0,0,0.2); }
  .dots span:nth-child(3) { background: #27c93f; border-color: rgba(0,0,0,0.2); }

  .title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11.5px;
    color: var(--ink-2);
    letter-spacing: 0.01em;
  }
  .title .origin { color: var(--ink-3); }
  .title .sep { color: var(--ink-4); }

  .caps {
    display: flex;
    gap: 6px;
    justify-content: flex-end;
    align-items: center;
    flex-wrap: wrap;
    font-size: 10px;
    letter-spacing: 0.06em;
  }
  .cap {
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--line);
    color: var(--ink-3);
  }
  .cap.on {
    color: var(--accent);
    border-color: rgba(52, 211, 153, 0.45);
    background: var(--accent-soft);
  }

  .surface {
    position: relative;
    height: var(--demo-h);
    background: #000;
  }
  iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    background: #000;
  }

  /* dev fallback (only renders during `astro dev`) */
  .dev-stub {
    position: absolute;
    inset: 0;
    padding: 28px 30px;
    overflow: auto;
    color: var(--ink-2);
    font-size: 12.5px;
    line-height: 1.85;
    background:
      radial-gradient(700px 380px at 100% 100%, rgba(52,211,153,0.05), transparent 65%),
      #060606;
  }
  .ds-frame { max-width: 720px; }
  .ds-row { display: grid; grid-template-columns: 22px 1fr; gap: 8px; align-items: baseline; }
  .ds-row.dim { color: var(--ink-3); }
  .ds-row.warn { color: var(--warn); }
  .ds-row em { font-style: normal; color: var(--ink); }
  .ds-prompt { color: var(--accent); }
  .ds-row.warn .ds-prompt { color: var(--warn); }
  .caret-block {
    display: inline-block;
    width: 0.6em;
    background: var(--accent);
    color: transparent;
    animation: stub-blink 1.05s steps(2, end) infinite;
  }
  @keyframes stub-blink { 50% { background: transparent; } }
  .ds-foot {
    margin-top: 24px;
    padding-top: 14px;
    border-top: 1px dashed var(--line);
    color: var(--ink-3);
    font-size: 11.5px;
  }
  .ds-mark {
    color: var(--ink);
    background: var(--panel-2);
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid var(--line);
  }
  /* faint grid overlay only on idle state of iframe perimeter; pointer-events none */
  .grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 24px 24px;
    mix-blend-mode: screen;
    mask-image: radial-gradient(120% 80% at 50% 0%, transparent 30%, #000 95%);
    -webkit-mask-image: radial-gradient(120% 80% at 50% 0%, transparent 30%, #000 95%);
    opacity: 0.5;
  }
  .scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(255, 255, 255, 0.014) 2px,
      rgba(255, 255, 255, 0.014) 3px
    );
    mix-blend-mode: overlay;
  }

  .status {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
    height: 36px;
    padding: 0 14px;
    border-top: 1px solid var(--line);
    font-size: 11px;
    color: var(--ink-3);
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.3) 100%);
  }
  .status em { font-style: normal; color: var(--ink-2); }
  .status .caret { color: var(--accent); margin-right: 6px; }
  .status .sep { margin: 0 8px; color: var(--ink-4); }
  .status .left, .status .mid, .status .right {
    display: flex;
    align-items: center;
    overflow: hidden;
    white-space: nowrap;
  }
  .status .right { justify-content: flex-end; }
  .kbd-row { display: flex; gap: 7px; align-items: center; }
  .kbd-row .dim { color: var(--ink-4); margin-right: 6px; }

  .phaseRing {
    padding: 2px 8px;
    border-radius: 999px;
    color: var(--ink-4);
    border: 1px solid var(--line);
    margin-right: 6px;
    letter-spacing: 0.04em;
  }
  .phaseRing.on {
    color: var(--accent);
    border-color: rgba(52, 211, 153, 0.45);
    background: var(--accent-soft);
    animation: phase-cycle 2.4s ease-in-out infinite;
  }
  @keyframes phase-cycle {
    0%, 100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.30); }
    50%      { box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.00); }
  }

  .caption {
    margin: 14px 0 0;
    color: var(--ink-3);
    font-size: 13px;
    max-width: 720px;
  }

  /* responsive: collapse the busy strip on narrow viewports */
  @media (max-width: 1080px) {
    .status { grid-template-columns: 1fr auto; }
    .status .right { display: none; }
    .status .mid { overflow-x: auto; scrollbar-width: none; }
    .status .mid::-webkit-scrollbar { display: none; }
  }
  @media (max-width: 720px) {
    .bar { grid-template-columns: auto 1fr; }
    .caps { display: none; }
    .surface { height: 460px; }
    .status { grid-template-columns: 1fr; height: auto; padding: 8px 12px; }
    .status .mid { display: none; }
  }
</style>
