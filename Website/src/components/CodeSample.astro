---
// Wrapped code panel that mirrors the existing Nothing-style code panel
// (file-name + language eyebrow + monospace body). Built around Astro's
// Shiki integration via <Code /> from astro:components is also fine but
// for marketing pages the structural shell is what we care about.
import { Code } from "astro:components";

interface Props {
  filename: string;
  language?: "swift" | "bash" | "json" | "typescript" | "shell";
  code: string;
}

const { filename, language = "swift", code } = Astro.props;
---

<div class="info-panel">
  <div class="info-panel-header">
    <span class="info-panel-header-file">{filename}</span>
    <span>{language}</span>
  </div>
  <div class="code-sample">
    <Code code={code} lang={language} theme="github-dark-default" />
  </div>
</div>
