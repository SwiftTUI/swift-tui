---
const steps = [
  {
    n: "01",
    label: "create the package",
    desc: "A Package.swift with one dependency on SwiftTUI and one executable target.",
  },
  {
    n: "02",
    label: "author an @main App",
    desc: "A struct conforming to App, with a Scene built from the SwiftUI-shaped primitives you already know.",
  },
  {
    n: "03",
    label: "swift run",
    desc: "Standard SwiftPM. Your app takes the alternate screen until you exit.",
  },
];
---
<section class="quickstart" id="quickstart">
  <div class="shell">
    <header class="head">
      <span class="eyebrow"><span class="num">/05</span>Quickstart</span>
      <h2>Two files. One <span class="mono">swift run</span>.</h2>
      <p class="lede">
        No code generators, no build scripts, no binaries to download &mdash;
        just SwiftPM. Copy the two files below into a new directory and run it.
      </p>
      <p class="prereq mono">
        <span class="prereq-label">prereq</span>
        <span>A Swift 6.3 toolchain on <span class="mono">PATH</span> &mdash; install it however you already manage Swift.</span>
      </p>
    </header>

    <div class="grid">
      <ol class="steps mono" aria-label="quickstart steps">
        {steps.map((step) => (
          <li class="step">
            <span class="step-n">{step.n}</span>
            <div class="step-body">
              <span class="step-label">{step.label}</span>
              <span class="step-desc">{step.desc}</span>
            </div>
          </li>
        ))}
      </ol>

      <article class="terminal">
        <div class="t-bar mono">
          <span class="dots" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="t-title">~/Projects/HelloTUI</span>
        </div>
        <pre class="t-body mono"><code><span class="cm"># build &amp; run — your app owns the terminal until you exit</span>
<span class="p">$</span> swift run HelloTUI
<span class="ok">›</span> alternate screen opens
<span class="ok">›</span> resolve · measure · place · semantics · draw · raster <span class="bar">·</span> <span class="commit">commit</span>
<span class="ok">›</span> press <span class="commit">Ctrl-D</span> to exit — your shell is restored</code></pre>
      </article>
    </div>

    <div class="files">
      <article class="file">
        <div class="file-bar mono">
          <span class="path">Package.swift</span>
          <span class="meta">swift-tools-version: 6.3</span>
        </div>
        <pre class="file-body mono"><code><span class="cm">// swift-tools-version: 6.3</span>
<span class="kw">import</span> <span class="ty">PackageDescription</span>

<span class="kw">let</span> package = <span class="ty">Package</span>(
  name: <span class="s">"HelloTUI"</span>,
  dependencies: [
    .package(
      url: <span class="s">"https://github.com/SwiftTUI/swift-tui"</span>,
      .upToNextMinor(from: <span class="s">"0.1.0"</span>)
    ),
  ],
  targets: [
    .executableTarget(
      name: <span class="s">"HelloTUI"</span>,
      dependencies: [
        .product(name: <span class="s">"SwiftTUI"</span>, package: <span class="s">"swift-tui"</span>),
      ]
    ),
  ]
)</code></pre>
      </article>

      <article class="file">
        <div class="file-bar mono">
          <span class="path">Sources/HelloTUI/HelloTUI.swift</span>
          <span class="meta">@main · terminal-native</span>
        </div>
        <pre class="file-body mono"><code><span class="kw">import</span> <span class="ty">SwiftTUI</span>

<span class="at">@main</span> <span class="kw">struct</span> <span class="ty">HelloTUI</span>: <span class="ty">App</span> &#123;
  <span class="kw">var</span> body: <span class="kw">some</span> <span class="ty">Scene</span> &#123;
    <span class="ty">WindowGroup</span>(<span class="s">"Hello"</span>) &#123;
      <span class="ty">VStack</span>(alignment: .leading, spacing: <span class="n">1</span>) &#123;
        <span class="ty">Text</span>(<span class="s">"Hello, terminal."</span>).bold()
        <span class="ty">Text</span>(<span class="s">"Press Ctrl-D to quit."</span>)
          .foregroundStyle(.muted)
      &#125;
      .padding(<span class="n">1</span>)
    &#125;
  &#125;
&#125;</code></pre>
      </article>
    </div>

    <p class="trailer">
      Targeting the browser? Pass <span class="mono">--swift-sdk</span> for a wasm
      SDK on the same <span class="mono">swift build</span> &mdash; the authoring
      code is unchanged. Embedding in a host app? Retain a
      <span class="mono">HostedSceneSession</span> through
      <span class="mono">SwiftUIHost</span>, or add
      <span class="mono">SwiftTUIWebHostCLI</span> for a localhost browser
      launch. Same <span class="mono">App</span> body, every target.
    </p>
  </div>
</section>

<style>
  .quickstart {
    padding: 96px 0 56px;
    border-top: 1px solid var(--line);
    margin-top: 64px;
  }
  .head { max-width: 760px; margin-bottom: 48px; }
  .head h2 { margin-top: 16px; }
  .head .lede { margin-top: 18px; max-width: 70ch; }

  .prereq {
    margin-top: 22px;
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    padding: 8px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--panel);
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.4;
  }
  .prereq-label {
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 10.5px;
  }

  .grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 18px;
    margin-bottom: 18px;
  }

  .steps {
    list-style: none;
    margin: 0;
    padding: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel);
  }
  .step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 14px;
    padding: 18px 20px;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }
  .step:last-child { border-bottom: 0; }
  .step-n {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.06em;
    padding-top: 2px;
  }
  .step-body { display: flex; flex-direction: column; gap: 4px; }
  .step-label {
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 0.005em;
  }
  .step-desc {
    color: var(--ink-3);
    font-family: var(--font-sans);
    font-size: 12.5px;
    line-height: 1.5;
  }

  .terminal {
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    overflow: hidden;
    background: #060606;
    display: flex;
    flex-direction: column;
  }
  .t-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--line);
    font-size: 11px;
    color: var(--ink-3);
    background: rgba(255,255,255,0.025);
  }
  .t-bar .dots { display: inline-flex; gap: 6px; }
  .t-bar .dots span {
    width: 8px; height: 8px; border-radius: 50%;
    background: #1f1f1f;
  }
  .t-bar .dots span:nth-child(1) { background: #ff5f56; }
  .t-bar .dots span:nth-child(2) { background: #ffbd2e; }
  .t-bar .dots span:nth-child(3) { background: #27c93f; }
  .t-bar .t-title { color: var(--ink-2); }

  .t-body {
    margin: 0;
    padding: 18px 18px;
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink-2);
    overflow-x: auto;
    flex: 1;
    white-space: pre;
  }
  .t-body .p  { color: var(--accent); margin-right: 6px; }
  .t-body .cm { color: var(--ink-4); font-style: italic; }
  .t-body .ok { color: var(--accent); margin-right: 6px; }
  .t-body .bar { color: var(--ink-4); }
  .t-body .commit { color: var(--accent); font-weight: 600; }

  .files {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .file {
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel);
    display: flex;
    flex-direction: column;
  }
  .file-bar {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--panel-2);
    gap: 10px;
  }
  .file-bar .path { color: var(--ink-2); }
  .file-bar .meta { margin-left: auto; color: var(--ink-4); }
  .file-body {
    margin: 0;
    padding: 18px 18px 22px;
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink);
    overflow-x: auto;
    flex: 1;
  }
  .file-body .kw { color: #d28cff; }
  .file-body .ty { color: #6ddfff; }
  .file-body .at { color: #f59e0b; }
  .file-body .s  { color: var(--accent); }
  .file-body .n  { color: #f59e0b; }
  .file-body .cm { color: var(--ink-4); font-style: italic; }

  .trailer {
    margin-top: 24px;
    color: var(--ink-3);
    font-size: 13px;
    line-height: 1.6;
    max-width: 76ch;
  }

  @media (max-width: 1080px) {
    .grid { grid-template-columns: 1fr; }
    .files { grid-template-columns: 1fr; }
  }
</style>
