---
---
<section class="snippet" id="authoring">
  <div class="shell">
    <header class="head">
      <span class="eyebrow"><span class="num">/04</span>Authoring &rarr; render</header>
      <h2>One <span class="mono">View</span>. Resolve, place, and rasterize, into cells.</h2>
      <p class="lede">
        At the lowest public runtime level, you can resolve and render any
        <span class="mono">View</span> into terminal text. Same code path your
        <span class="mono">App</span> takes inside <span class="mono">RunLoop</span>, exposed for tests,
        snapshots, and CI fixtures.
      </p>
    </header>

    <div class="grid">
      <article class="pane source">
        <div class="pane-bar mono">
          <span class="path">BuildSummary.swift</span>
          <span class="meta">38 cells × 8 rows · proposal</span>
        </div>
        <pre class="code mono"><code><span class="kw">import</span> <span class="ty">SwiftTUI</span>

<span class="kw">struct</span> <span class="ty">BuildSummary</span>: <span class="ty">View</span> &#123;
  <span class="kw">var</span> body: <span class="kw">some</span> <span class="ty">View</span> &#123;
    <span class="ty">VStack</span>(alignment: .leading, spacing: <span class="n">0</span>) &#123;
      <span class="ty">Text</span>(<span class="s">"Deploy Queue"</span>).bold()
      <span class="ty">Divider</span>()
      <span class="ty">ProgressView</span>(<span class="s">"Release"</span>, value: <span class="n">18</span>, total: <span class="n">24</span>)
      <span class="ty">LabeledContent</span>(<span class="s">"Window"</span>, value: <span class="s">"staging"</span>)
      <span class="ty">LabeledContent</span>(<span class="s">"Owner"</span>,  value: <span class="s">"infra"</span>)
    &#125;
    .padding(.init(horizontal: <span class="n">1</span>, vertical: <span class="n">0</span>))
  &#125;
&#125;

<span class="kw">let</span> renderer = <span class="ty">DefaultRenderer</span>()
<span class="kw">let</span> frame = renderer.render(
  <span class="ty">BuildSummary</span>(),
  proposal: .init(width: <span class="n">40</span>, height: <span class="n">8</span>)
)</code></pre>
      </article>

      <article class="pane output">
        <div class="pane-bar mono">
          <span class="dotline">
            <span class="d red"></span><span class="d yellow"></span><span class="d green"></span>
          </span>
          <span class="path">stdout</span>
          <span class="meta">capability: previewUnicode</span>
        </div>
        <pre class="render mono"><code> <span class="b">Deploy Queue</span>
 ────────────────────────────────────
 Release
 <span class="bar">█████████████████████████</span><span class="bar-dim">░░░░░░░░</span> <span class="num">18</span> / <span class="num">24</span>
 Window                       <span class="hl">staging</span>
 Owner                          <span class="hl">infra</span>

 <span class="cursor">_</span>                                     </code></pre>
        <div class="pane-foot mono">
          <span><span class="caret">›</span> resolved &mdash; 14 nodes</span>
          <span>diff: 6 cells</span>
          <span>commit: 0.31&thinsp;ms</span>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .snippet {
    padding: 88px 0 24px;
    border-top: 1px solid var(--line);
    margin-top: 56px;
  }
  .head { max-width: 760px; margin-bottom: 48px; }
  .head h2 { margin-top: 16px; }
  .head .lede { margin-top: 18px; max-width: 70ch; }

  .grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 18px;
    align-items: stretch;
  }
  .pane {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel);
  }
  .pane-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    font-size: 11px;
    color: var(--ink-3);
    background: var(--panel-2);
  }
  .pane-bar .path { color: var(--ink-2); }
  .pane-bar .meta { margin-left: auto; color: var(--ink-4); }
  .dotline { display: inline-flex; gap: 6px; }
  .dotline .d {
    width: 8px; height: 8px; border-radius: 50%;
    background: #1f1f1f;
  }
  .dotline .d.red { background: #ff5f56; }
  .dotline .d.yellow { background: #ffbd2e; }
  .dotline .d.green { background: #27c93f; }

  .code {
    margin: 0;
    padding: 18px 18px 22px;
    font-size: 12.5px;
    line-height: 1.65;
    color: var(--ink);
    overflow-x: auto;
    flex: 1;
  }
  .code .kw { color: #d28cff; }
  .code .ty { color: #6ddfff; }
  .code .s  { color: var(--accent); }
  .code .n  { color: #f59e0b; }
  .code .at { color: #f59e0b; }

  .output { background: #060606; }
  .render {
    margin: 0;
    padding: 22px 18px;
    font-size: 13px;
    line-height: 1.45;
    color: var(--ink-2);
    overflow-x: auto;
    background:
      linear-gradient(180deg, rgba(52,211,153,0.04) 0%, transparent 18%, transparent 100%);
    flex: 1;
    min-height: 280px;
    white-space: pre;
  }
  .render .b { color: var(--ink); font-weight: 600; }
  .render .bar { color: var(--accent); }
  .render .bar-dim { color: var(--ink-4); }
  .render .num { color: #f59e0b; }
  .render .hl { color: var(--ink); }
  .render .cursor {
    display: inline-block;
    width: 0.6em;
    background: var(--accent);
    color: transparent;
    animation: blink 1.05s steps(2, end) infinite;
  }
  @keyframes blink { 50% { background: transparent; } }

  .pane-foot {
    display: flex;
    gap: 18px;
    padding: 10px 14px;
    border-top: 1px solid var(--line);
    font-size: 11px;
    color: var(--ink-3);
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.4));
  }
  .pane-foot .caret { color: var(--accent); margin-right: 6px; }

  @media (max-width: 1080px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
