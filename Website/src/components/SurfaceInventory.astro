---
type Row = { name: string; note?: string };
type Group = { title: string; rows: Row[] };

const authoring: Group[] = [
  {
    title: "Layout & containers",
    rows: [
      { name: "VStack · HStack · ZStack · Spacer · Divider", note: "" },
      { name: "LazyVStack · LazyHStack · ScrollView", note: "viewport-lazy placement" },
      { name: "List · OutlineGroup · Table · Section · GroupBox", note: "" },
      { name: "Layout · AnyLayout · ViewThatFits · GeometryReader", note: "public protocol for custom layout" },
    ],
  },
  {
    title: "Controls & primitives",
    rows: [
      { name: "Text · TextFigure · Label · Image", note: "FIGlet figures · PNG / baseline JPEG images" },
      { name: "Button · Link · Toggle · Slider · Stepper", note: "sanitized OSC 8 hyperlinks when supported" },
      { name: "TextField · TextEditor · SecureField · Picker · Menu", note: "" },
      { name: "ProgressView · DisclosureGroup · ControlGroup", note: "" },
    ],
  },
  {
    title: "Presentation & workflow",
    rows: [
      { name: "alert · confirmationDialog · sheet · popover · toast", note: "terminal-native modal & non-modal surfaces" },
      { name: "paletteSheet · Panel · .keyCommand · .paletteCommand", note: "action scopes and commands" },
      { name: ".toolbar · .toolbarItem", note: "" },
    ],
  },
  {
    title: "State · observation · focus",
    rows: [
      { name: "@State · @Binding · @Bindable", note: "graph-scoped invalidation and observation" },
      { name: "@FocusState · @FocusedValue · @FocusedBinding", note: "" },
      { name: "@Environment · PreferenceKey · anchor preferences", note: "" },
    ],
  },
];

const runtime: Group[] = [
  {
    title: "Runtime & scenes",
    rows: [
      { name: "DefaultRenderer · FrameArtifacts", note: "snapshot rendering and frame inspection" },
      { name: "RunLoop · TerminalHost · TerminalCapabilityProfile", note: "capability-aware interactive sessions" },
      { name: "App · Scene · WindowGroup · TabView", note: "@MainActor scene declarations" },
      { name: "SceneManifest · HostedSceneSession", note: "retained hosted sessions for host packages" },
      { name: "NavigationStack destinations", note: "binding-driven destination presentation" },
      { name: "Pty-backed secondary scenes", note: "Unix-domain-socket discovery" },
    ],
  },
  {
    title: "Charts",
    rows: [
      { name: "BarChart · ColumnChart · StackedBarChart · ComparisonChart", note: "" },
      { name: "LineChart · Sparkline · Timeline · HeatStrip · CalendarHeatmap", note: "" },
      { name: "BulletChart · ThresholdGauge · Meter · Legend", note: "" },
    ],
  },
];
---
<section class="surface" id="surface">
  <div class="shell">
    <header class="head">
      <span class="eyebrow"><span class="num">/03</span>Public surface</span>
      <h2>A deliberate subset of SwiftUI.</h2>
      <p class="lede">
        Layout, state, focus, and presentation &mdash; plus the runtime and
        scene types that drive them, and a peer charts product. Terminal-only
        chrome that would bend the public authoring story stays out of core.
        The full per-symbol reference lives in the DocC catalogs.
      </p>
    </header>

    <div class="cols">
      <div class="col">
        <div class="col-head mono">
          <span>AUTHORING</span>
        </div>
        {authoring.map((group) => (
          <section class="group">
            <h4 class="group-title mono">{group.title}</h4>
            <ul class="rows">
              {group.rows.map((row) => (
                <li class="row">
                  <div class="row-head">
                    <span class="name mono">{row.name}</span>
                  </div>
                  {row.note && <span class="note">{row.note}</span>}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <div class="col">
        <div class="col-head mono">
          <span>RUNTIME · SCENES · CHARTS</span>
        </div>
        {runtime.map((group) => (
          <section class="group">
            <h4 class="group-title mono">{group.title}</h4>
            <ul class="rows">
              {group.rows.map((row) => (
                <li class="row">
                  <div class="row-head">
                    <span class="name mono">{row.name}</span>
                  </div>
                  {row.note && <span class="note">{row.note}</span>}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .surface {
    padding: 96px 0 56px;
    border-top: 1px solid var(--line);
    margin-top: 64px;
  }
  .head { max-width: 760px; margin-bottom: 48px; }
  .head h2 { margin-top: 16px; }
  .head .lede { margin-top: 18px; max-width: 70ch; }

  .cols {
    display: grid;
    grid-template-columns: 1.18fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }
  .col {
    padding: 0;
    border-right: 1px solid var(--line);
  }
  .col:last-child { border-right: 0; }

  .col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 14px 22px;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
    color: var(--ink-3);
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  .group {
    border-bottom: 1px solid var(--line);
    padding: 6px 0 10px;
  }
  .group:last-child { border-bottom: 0; }
  .group-title {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px 6px;
    color: var(--ink-2);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .group-title::before {
    content: "";
    width: 8px;
    height: 1px;
    background: var(--ink-4);
    flex: 0 0 auto;
  }

  .rows { list-style: none; margin: 0; padding: 0; }
  .row {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 7px 22px 9px;
  }
  .row-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .row .name {
    color: var(--ink);
    font-size: 12.5px;
    letter-spacing: 0.005em;
    line-height: 1.4;
  }
  .row .note {
    color: var(--ink-3);
    font-size: 11.5px;
    letter-spacing: -0.005em;
    line-height: 1.5;
    max-width: 60ch;
  }

  @media (max-width: 1080px) {
    .cols { grid-template-columns: 1fr; }
    .col { border-right: 0; border-bottom: 1px solid var(--line); }
    .col:last-child { border-bottom: 0; }
  }
  @media (max-width: 640px) {
    .row { padding: 8px 18px 10px; }
    .col-head { padding: 14px 18px; }
    .group-title { padding: 14px 18px 6px; }
  }
</style>
