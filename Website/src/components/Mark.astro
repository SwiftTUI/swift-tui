---
import logo from "../../logo/md.gif";

interface Props { size?: number }
const { size = 22 } = Astro.props;
const logoSrc = typeof logo === "string" ? logo : logo.src;
const radius = Math.max(5, Math.round(size * 0.2));
---
<img
  class="mark"
  src={logoSrc}
  width={size}
  height={size}
  style={`--mark-size:${size}px;--mark-radius:${radius}px`}
  alt=""
  aria-hidden="true"
  decoding="async"
/>

<style>
  .mark {
    width: var(--mark-size);
    height: var(--mark-size);
    border-radius: var(--mark-radius);
    object-fit: cover;
  }
</style>
