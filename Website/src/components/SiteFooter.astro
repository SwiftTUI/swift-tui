---
import Mark from "./Mark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();
---
<footer class="site-foot">
  <div class="shell">
    <div class="row top">
      <a class="brand" href={`${base}/`}>
        <Mark size={20} />
        <span class="wordmark">SwiftTUI</span>
      </a>
      <div class="cols">
        <div class="col">
          <h5 class="mono">framework</h5>
          <a href={`${base}/docs/documentation/swifttui/`}>DocC reference</a>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI" rel="noreferrer noopener">github / GoodHatsLLC</a>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/issues" rel="noreferrer noopener">issues &amp; tracking</a>
        </div>
        <div class="col">
          <h5 class="mono">runners</h5>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Platforms/CLI" rel="noreferrer noopener">SwiftTUICLI</a>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Platforms/WASI" rel="noreferrer noopener">SwiftTUIWASI</a>
        </div>
        <div class="col">
          <h5 class="mono">hosts</h5>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Platforms/SwiftUI" rel="noreferrer noopener">SwiftUIHost</a>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Platforms/WebHost" rel="noreferrer noopener">SwiftTUIWebHost</a>
        </div>
        <div class="col">
          <h5 class="mono">examples</h5>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Examples/gallery" rel="noreferrer noopener">gallery</a>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Examples/gifeditor" rel="noreferrer noopener">gifeditor</a>
          <a href="https://github.com/GoodHatsLLC/SwiftTUI/tree/main/Examples/WebExample" rel="noreferrer noopener">WebExample</a>
        </div>
      </div>
    </div>

    <div class="row bottom mono">
      <span class="dim">© {year} GoodHats</span>
      <span class="dim sep">·</span>
      <span class="dim">Swift 6.3.1 toolchain via swiftly</span>
      <span class="dim sep">·</span>
      <a class="dim foot-link" href="https://github.com/GoodHatsLLC/SwiftTUI/blob/main/LICENSE" rel="noreferrer noopener">License</a>
      <span class="grow"></span>
      <span class="probe">
        <span class="dim">resolve</span>
        <span class="dim">·</span>
        <span class="dim">measure</span>
        <span class="dim">·</span>
        <span class="dim">place</span>
        <span class="dim">·</span>
        <span class="dim">semantics</span>
        <span class="dim">·</span>
        <span class="dim">draw</span>
        <span class="dim">·</span>
        <span class="dim">raster</span>
        <span class="dim">·</span>
        <span class="active">commit</span>
        <span class="cursor"></span>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-foot {
    border-top: 1px solid var(--line);
    margin-top: 80px;
    padding: 56px 0 28px;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.4));
  }
  .row.top {
    display: grid;
    grid-template-columns: minmax(160px, 220px) 1fr;
    gap: 36px;
    align-items: start;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }
  .wordmark { font-weight: 500; letter-spacing: -0.005em; }
  .cols {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 24px;
  }
  .col { display: flex; flex-direction: column; gap: 6px; }
  .col h5 {
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-4);
    margin: 0 0 4px;
  }
  .col a {
    font-size: 12.5px;
    color: var(--ink-2);
    transition: color 160ms ease;
  }
  .col a:hover { color: var(--ink); }

  .row.bottom {
    margin-top: 36px;
    padding-top: 18px;
    border-top: 1px dashed var(--line);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 10.5px;
    color: var(--ink-3);
  }
  .row.bottom .dim { color: var(--ink-4); }
  .row.bottom .sep { padding: 0 4px; }
  .row.bottom .grow { flex: 1; }
  .row.bottom .foot-link { transition: color 160ms ease; }
  .row.bottom .foot-link:hover { color: var(--ink-2); }
  .probe {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .probe .active { color: var(--accent); }
  .probe .cursor {
    display: inline-block;
    width: 8px;
    height: 12px;
    background: var(--accent);
    margin-left: 2px;
    animation: blink 1.1s steps(2) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  @media (max-width: 920px) {
    .row.top { grid-template-columns: 1fr; }
    .cols { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 540px) {
    .cols { grid-template-columns: 1fr; }
  }
</style>
