---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const repo = "https://github.com/GoodHatsLLC/swift-terminal-ui";
---

<footer class="site-footer">
  <span>TerminalUI</span>
  <div class="site-footer-links">
    <a href={`${base}/api/`}>API Reference</a>
    <a href={`${base}/design/architecture`}>Architecture</a>
    <a href={`${base}/design/runtime`}>Runtime</a>
    <a href={`${base}/decisions`}>Decisions</a>
    <a href={repo} target="_blank" rel="noreferrer">GitHub</a>
  </div>
</footer>
