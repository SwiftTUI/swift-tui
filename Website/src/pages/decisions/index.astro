---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const decisions = await getCollection("decisions");
const sorted = decisions
  .slice()
  .sort((a, b) => a.data.adr.localeCompare(b.data.adr));

const statusStyle: Record<string, string> = {
  accepted: "color: var(--text-display);",
  proposed: "color: var(--accent);",
  superseded: "color: var(--text-disabled);",
  reverted: "color: var(--accent);",
};
---

<Base
  title="Decisions"
  description="Architecture decision records — short, dated, and durable."
  pageKey="design"
>
  <article class="prose article-body" style="margin-top: var(--space-2xl);">
    <p class="eyebrow">Decisions</p>
    <h1>What we ruled in. What we ruled out.</h1>
    <p>
      Each entry is an architecture decision record (ADR) in 200–400 words.
      Read in any order — they're written to be durable, dated, and
      independently legible. A new contributor who reads ten ADRs has more
      useful context than one who reads three full proposals.
    </p>
    <p>
      The format and lifecycle are documented in
      <a href="https://github.com/GoodHatsLLC/swift-terminal-ui/blob/main/docs/decisions/README.md">docs/decisions/README.md</a>.
      Each ADR's source markdown lives at
      <code>docs/decisions/&lt;number&gt;-&lt;slug&gt;.md</code>.
    </p>
  </article>
  <section class="info-block" style="border-top: 1px solid var(--border); border-bottom: 0;">
    <div class="info-copy" style="display: none;"></div>
    <div style="grid-column: 1 / -1; display: grid; gap: 1px; background: var(--border); border: 1px solid var(--border);">
      {
        sorted.map((d) => {
          const slug = d.id;
          return (
            <a
              href={`${base}/decisions/${slug}`}
              style="display: grid; grid-template-columns: 80px 1fr auto; gap: var(--space-md); padding: var(--space-lg) var(--space-xl); background: var(--black); text-decoration: none; color: inherit; transition: background-color var(--ease);"
              onmouseover="this.style.backgroundColor='var(--surface)';"
              onmouseout="this.style.backgroundColor='var(--black)';"
            >
              <span style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; color: var(--text-disabled); padding-top: 4px;">
                ADR-{d.data.adr}
              </span>
              <div>
                <h3 style="margin: 0; font-family: var(--font-body); font-size: 1.125rem; font-weight: 500; color: var(--text-display);">
                  {d.data.title}
                </h3>
                <p style="margin: var(--space-sm) 0 0; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em; color: var(--text-secondary);">
                  {d.data.date.toISOString().slice(0, 10)}
                </p>
              </div>
              <span style={`font-family: var(--font-mono); font-size: 11px; letter-spacing: var(--label-tracking); text-transform: uppercase; ${statusStyle[d.data.status] ?? ""} padding-top: 4px;`}>
                {d.data.status}
              </span>
            </a>
          );
        })
      }
    </div>
  </section>
</Base>
