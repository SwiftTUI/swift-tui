---
// Detail page for each ADR. Sources from /docs/decisions/.
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "@layouts/Base.astro";
import ArticleHeader from "@components/ArticleHeader.astro";

export async function getStaticPaths() {
  const decisions = await getCollection("decisions");
  return decisions.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"decisions">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const sourcePath = `docs/decisions/${entry.id}.md`;

const statusLabel: Record<string, string> = {
  accepted: "Accepted",
  proposed: "Proposed",
  superseded: "Superseded",
  reverted: "Reverted",
};
---

<Base
  title={`ADR-${entry.data.adr} · ${entry.data.title}`}
  description={`${statusLabel[entry.data.status]} on ${entry.data.date.toISOString().slice(0, 10)} — ${entry.data.title}`}
  pageKey="design"
>
  <ArticleHeader
    eyebrow={`ADR-${entry.data.adr} · ${statusLabel[entry.data.status]}`}
    title={entry.data.title}
    source={sourcePath}
    lastReviewed={entry.data.date}
  />
  {
    entry.data.sources && entry.data.sources.length > 0 && (
      <section style="max-width: 70ch; margin: 0 auto; padding: var(--space-md) 0; border-bottom: 1px solid var(--border);">
        <p
          style="margin: 0 0 var(--space-sm); font-family: var(--font-mono); font-size: 11px; letter-spacing: var(--label-tracking); text-transform: uppercase; color: var(--text-disabled);"
        >
          Sources
        </p>
        <ul style="margin: 0; padding-left: var(--space-lg); font-family: var(--font-mono); font-size: 0.875rem; line-height: 1.8; color: var(--text-secondary);">
          {entry.data.sources.map((src) => (
            <li>
              <a
                href={`https://github.com/GoodHatsLLC/swift-terminal-ui/blob/main/${src}`}
                target="_blank"
                rel="noreferrer"
                style="color: var(--text-secondary); border-bottom: 1px solid var(--border-visible);"
              >
                {src} ↗
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
  <article class="prose article-body">
    <Content />
  </article>
</Base>
