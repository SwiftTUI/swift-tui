---
import Base from "@layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// DocC is published at /<base>/docs/ alongside the rest of the site. Each
// module has its own browseable archive under /docs/documentation/<module>.
// We deep-link from the cards below.
//
// The /docs/ path is GitHub-Pages-historical and predates this Astro site.
// Keeping it stable preserves existing bookmarks; this page is the
// human-facing entry point that the site nav and footer point to.
const doccPath = `${base}/docs/documentation`;

const modules = [
  {
    name: "TerminalUI",
    slug: "terminalui",
    role: "Runtime",
    summary:
      "DefaultRenderer, RunLoop, App / Scene / WindowGroup, terminal host integration, and capability-aware presentation.",
    headline: "import TerminalUI",
  },
  {
    name: "View",
    slug: "view",
    role: "Authoring",
    summary:
      "The SwiftUI-shaped authoring surface — body-only View, ViewModifier algebra, layouts, controls, focus, gestures, Canvas.",
    headline: "All the body-only types",
  },
  {
    name: "Core",
    slug: "core",
    role: "Pipeline",
    summary:
      "The pure pipeline data model: geometry, layout engine, semantic extractor, rasterizer, commit planner.",
    headline: "Pipeline + data products",
  },
  {
    name: "TerminalUICharts",
    slug: "terminaluicharts",
    role: "Charts",
    summary:
      "Compact chart and metric views — BarChart, Sparkline, Meter, ThresholdGauge, Timeline, Legend.",
    headline: "Dashboard primitives",
  },
];

// Common entry symbols, deep-linked into DocC. These are hand-curated;
// adding more is a one-line edit.
const quickLinks = [
  { label: "App", href: `${doccPath}/terminalui/app/` },
  { label: "WindowGroup", href: `${doccPath}/terminalui/windowgroup/` },
  { label: "RunLoop", href: `${doccPath}/terminalui/runloop/` },
  { label: "DefaultRenderer", href: `${doccPath}/terminalui/defaultrenderer/` },
  { label: "View", href: `${doccPath}/view/view/` },
  { label: "State", href: `${doccPath}/view/state/` },
  { label: "Binding", href: `${doccPath}/view/binding/` },
  { label: "FocusState", href: `${doccPath}/view/focusstate/` },
  { label: "Layout", href: `${doccPath}/view/layout/` },
  { label: "Canvas", href: `${doccPath}/view/canvas/` },
  { label: "Sparkline", href: `${doccPath}/terminaluicharts/sparkline/` },
  { label: "Meter", href: `${doccPath}/terminaluicharts/meter/` },
];
---

<Base
  title="API Reference"
  description="DocC-generated symbol reference for TerminalUI, View, Core, and TerminalUICharts."
  pageKey="design"
>
  <article class="prose article-body" style="margin-top: var(--space-2xl);">
    <p class="eyebrow">API Reference</p>
    <h1>Every public symbol.</h1>
    <p>
      The reference below is generated by DocC from the in-source
      documentation comments and curated <code>## Topics</code> sections of
      each catalog. The four modules are bundled into a single combined
      archive, so symbols cross-reference correctly across boundaries.
    </p>
    <p>
      For narrative documentation — architecture, runtime, design rationale —
      see <a href={`${base}/design`}>design</a>. For tutorials, see
      <a href={`${base}/learn`}>learn</a>. The API reference is for symbol-level
      lookup.
    </p>
  </article>

  <section class="info-block" style="border-top: 1px solid var(--border);">
    <div class="info-copy">
      <p class="section-label">Modules</p>
      <h2>Four products. One archive.</h2>
      <p>
        Each product has a curated module landing with topic groups for the
        symbols an author actually uses first.
      </p>
    </div>
    <div class="card-grid" style="grid-column: 1 / -1;">
      {
        modules.map((m, i) => (
          <a
            class="card"
            href={`${doccPath}/${m.slug}/`}
            data-index={String(i + 1).padStart(2, "0")}
          >
            <h3>{m.name}</h3>
            <p>{m.summary}</p>
            <span class="card-tag">
              {m.role} · {m.headline}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="info-block">
    <div class="info-copy">
      <p class="section-label">Quick lookup</p>
      <h2>Common entry points.</h2>
      <p>
        Direct deep-links into the most-used symbols. The full archive is
        searchable from any DocC page via the in-archive search bar.
      </p>
    </div>
    <div class="info-panel" style="padding: var(--space-xl);">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--space-sm);">
        {
          quickLinks.map((link) => (
            <a
              href={link.href}
              style="padding: var(--space-md); border: 1px solid var(--border); font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; color: var(--text-primary); text-decoration: none; transition: border-color var(--ease), color var(--ease);"
              onmouseover="this.style.borderColor='var(--text-display)'; this.style.color='var(--text-display)';"
              onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-primary)';"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="info-block" style="border-bottom: 0;">
    <div class="info-copy">
      <p class="section-label">Build it locally</p>
      <h2>Generate the archive.</h2>
      <p>
        DocC archives can be generated and served locally for offline
        reading. The repo's GitHub Actions workflow uses the same command.
      </p>
    </div>
    <div class="info-panel">
      <div class="info-panel-header">
        <span class="info-panel-header-file">zsh</span>
        <span>bash</span>
      </div>
      <pre class="code-sample" style="white-space: pre;"><code>swiftly run swift package \
  --allow-writing-to-directory .build-docs \
  generate-documentation \
  --target Core \
  --target View \
  --target TerminalUI \
  --target TerminalUICharts \
  --enable-experimental-combined-documentation \
  --transform-for-static-hosting \
  --output-path .build-docs

# Serve locally
swiftly run swift package \
  --disable-sandbox \
  preview-documentation \
  --target TerminalUI</code></pre>
    </div>
  </section>
</Base>
