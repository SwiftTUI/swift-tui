---
import Base from "@layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const tutorials = [
  {
    n: "01",
    title: "First app",
    body: "App / Scene / WindowGroup / View / @State.",
    href: `${base}/start`,
    duration: "5 min",
  },
  {
    n: "02",
    title: "State and bindings",
    body: "@State, @Binding, @Observable, and the repo-owned @Bindable.",
    href: `${base}/learn/state-and-bindings`,
    duration: "10 min",
  },
  {
    n: "03",
    title: "Focus and keybindings",
    body: "Focus chain, .focusable, ActionScope, .keyCommand, .paletteCommand.",
    href: `${base}/learn/focus-and-keybindings`,
    duration: "12 min",
  },
  {
    n: "04",
    title: "Lists and selection",
    body: "List, OutlineGroup, Table, selection bindings, the canonical TUI pattern.",
    href: `${base}/learn/lists-and-selection`,
    duration: "8 min",
  },
  {
    n: "05",
    title: "Presentations",
    body: "alert, confirmationDialog, sheet, toast as terminal-native overlays.",
    href: `${base}/learn/presentations`,
    duration: "7 min",
  },
  {
    n: "06",
    title: "Custom layouts",
    body: "Layout protocol, the parent-proposes-child-chooses contract, SendableLayout.",
    href: `${base}/learn/custom-layouts`,
    duration: "15 min",
  },
  {
    n: "07",
    title: "Gestures and Canvas",
    body: "Drag, hover, Canvas, Braille subpixels, half-block pixel grids.",
    href: `${base}/learn/gestures-and-canvas`,
    duration: "12 min",
  },
  {
    n: "08",
    title: "Charts and dashboards",
    body: "BarChart, Sparkline, Meter, Timeline — composing dense status views.",
    href: `${base}/learn/charts-and-dashboards`,
    duration: "10 min",
  },
  {
    n: "09",
    title: "Images",
    body: "PNG, JPEG, GIF + Kitty/Sixel + cell fallback. One Image type, capability-aware.",
    href: `${base}/learn/images`,
    duration: "8 min",
  },
];
---

<Base
  title="Learn"
  description="Tutorials and how-to guides for building TUIs with TerminalUI."
  pageKey="learn"
>
  <article class="prose article-body" style="margin-top: var(--space-2xl);">
    <p class="eyebrow">Learn</p>
    <h1>Nine tutorials, ordered by need.</h1>
    <p>
      Each tutorial is a single-page worked example with runnable code. They
      assume you've completed <a href={`${base}/start`}>Get started</a> and
      have a hello world running.
    </p>
    <p style="color: var(--text-disabled); font-size: 0.9rem;">
      Tutorial 01 lives on the <a href={`${base}/start`}>Get started</a>
      page. The remaining pages continue from that same package setup.
    </p>
  </article>
  <section class="info-block" style="border-top: 1px solid var(--border);">
    <div class="info-copy" style="display: none;"></div>
    <div class="card-grid card-grid--three" style="grid-column: 1 / -1;">
      {
        tutorials.map((t) => (
          <a class="card" href={t.href} data-index={t.n}>
            <h3>{t.title}</h3>
            <p>{t.body}</p>
            <span class="card-tag">
              Tutorial · {t.duration}
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Base>
