---
import Base from "@layouts/Base.astro";
import { docOverlays } from "@/lib/doc-overlays";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const policies = Object.values(docOverlays)
  .filter((o) => o.section === "policy")
  .sort((a, b) => a.order - b.order);
---

<Base
  title="Policy"
  description="Guardrails for new public APIs, AnyView/AnyScene rules, and structured concurrency boundaries."
  pageKey="policy"
>
  <article class="prose article-body" style="margin-top: var(--space-2xl);">
    <p class="eyebrow">Policy</p>
    <h1>Guardrails.</h1>
    <p>
      These pages are the bar PRs are held to. They define what the public
      surface looks like, how new symbols are evaluated, and what concurrency
      and erasure escape hatches are permitted.
    </p>
  </article>
  <section class="info-block" style="border-top: 1px solid var(--border);">
    <div class="info-copy" style="display: none;"></div>
    <div class="card-grid card-grid--three" style="grid-column: 1 / -1;">
      {
        policies.map((d, i) => (
          <a class="card" href={`${base}/${d.slug}`} data-index={String(i + 1).padStart(2, "0")}>
            <h3>{d.title}</h3>
            <p>{d.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
