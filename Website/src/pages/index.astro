---
// Stub site. The deploy workflow mounts the WebExample WASI demo at
// /webexample/ on the same origin, so this iframe is same-origin and
// inherits cross-origin isolation from the parent page automatically.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const iframeSrc = `${base}/webexample/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TerminalUI</title>
    <meta name="description" content="TerminalUI WebExample." />
  </head>
  <body>
    <iframe src={iframeSrc} title="TerminalUI WebExample"></iframe>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    background: #000;
  }
  iframe {
    width: 100vw;
    height: 100vh;
    border: 0;
    display: block;
  }
</style>
