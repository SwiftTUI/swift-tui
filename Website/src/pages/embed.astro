---
// Bare-iframe fallback. Useful for embedding the demo into another page
// that already provides chrome (e.g. a docs viewer or talk slide).
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const iframeSrc = `${base}/webexample/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SwiftTUI WebExample</title>
    <meta name="description" content="SwiftTUI WebExample WASI demo." />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <iframe src={iframeSrc} title="SwiftTUI WebExample"></iframe>
  </body>
</html>

<style is:global>
  html, body { margin: 0; padding: 0; height: 100%; background: #000; }
  iframe { width: 100vw; height: 100vh; border: 0; display: block; }
</style>
