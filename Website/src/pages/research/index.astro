---
import Base from "@layouts/Base.astro";
import { docOverlays } from "@/lib/doc-overlays";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const research = Object.values(docOverlays)
  .filter((o) => o.section === "research")
  .sort((a, b) => a.order - b.order);
---

<Base
  title="Research"
  description="Background reads — non-normative material that informed TerminalUI's design decisions."
  pageKey="research"
>
  <article class="prose article-body" style="margin-top: var(--space-2xl);">
    <p class="eyebrow">Research</p>
    <h1>Background, not doctrine.</h1>
    <p>
      These documents are the inputs that shaped the framework's principles
      and architecture. Treat them as evidence, not as policy — the doctrine
      itself lives in <a href={`${base}/principles`}>principles</a>.
    </p>
  </article>
  <section class="info-block" style="border-top: 1px solid var(--border);">
    <div class="info-copy" style="display: none;"></div>
    <div class="card-grid" style="grid-column: 1 / -1;">
      {
        research.map((d, i) => (
          <a class="card" href={`${base}/${d.slug}`} data-index={String(i + 1).padStart(2, "0")}>
            <h3>{d.title}</h3>
            <p>{d.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
