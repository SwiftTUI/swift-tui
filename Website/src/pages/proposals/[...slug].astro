---
// Detail pages for each active proposal. Sourced from /docs/proposals/.
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "@layouts/Base.astro";
import ArticleHeader from "@components/ArticleHeader.astro";
import { proposalEntries, activeProposalSlugs } from "@/lib/proposal-status";

export async function getStaticPaths() {
  const proposals = await getCollection("proposals");
  const activeSlugs = new Set(activeProposalSlugs());
  const paths: Array<{
    params: { slug: string };
    props: { entry: CollectionEntry<"proposals">; meta: typeof proposalEntries[string] };
  }> = [];
  for (const entry of proposals) {
    if (!activeSlugs.has(entry.id)) continue;
    paths.push({
      params: { slug: entry.id },
      props: { entry, meta: proposalEntries[entry.id] },
    });
  }
  return paths;
}

interface Props {
  entry: CollectionEntry<"proposals">;
  meta: typeof proposalEntries[string];
}

const { entry, meta } = Astro.props;
const { Content } = await render(entry);

// Build a github source URL. The id is lowercased; we store the original
// filename casing in proposal-status.ts when needed. For now we rely on
// the convention that proposal files use UPPERCASE_WITH_UNDERSCORES.
const id = entry.id;
const isNested = id.includes("/");
const filename = isNested
  ? `${id.split("/")[0]}/${id.split("/")[1]?.toUpperCase()}.md`
  : `${id.toUpperCase()}.md`;
const sourceUrl = `https://github.com/GoodHatsLLC/swift-terminal-ui/blob/main/docs/proposals/${filename}`;
---

<Base title={meta.title} description={meta.summary} pageKey="design">
  <ArticleHeader
    eyebrow="Proposal · Active"
    title={meta.title}
    description={meta.summary}
  />
  <div class="article-meta" style="padding: var(--space-md) 0; max-width: 70ch; margin: 0 auto;">
    <a class="article-meta-source" href={sourceUrl} target="_blank" rel="noreferrer">
      Source: docs/proposals/{filename} ↗
    </a>
  </div>
  <article class="prose article-body">
    <Content />
  </article>
</Base>
