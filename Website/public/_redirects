# Cloudflare Pages rewrites for generated artifacts composed by
# .github/workflows/cloudflare-pages.yml.
#
# The deploy workflow removes DocC's per-symbol HTML shell copies to keep the
# artifact below Pages' file-count limit. The DocC app is a JavaScript shell
# backed by /docs/data/, so direct links can route through the single shell.
#
# Destination must be `/docs/` (canonical directory form), not
# `/docs/index.html`. Pages canonicalizes asset URLs ending in `/index.html`
# to their directory equivalent on upload, so a 200 rewrite to
# `/docs/index.html` silently fails to resolve and the request falls
# through to the project's homepage fallback.
/docs/documentation /docs/ 200
/docs/documentation/* /docs/ 200
