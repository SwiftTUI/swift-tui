# Cloudflare Pages headers. Read at the root of the deployed artifact.
#
# Layout (set in .github/workflows/cloudflare-pages.yml):
#   /              <- Astro stub (this Website/ project)
#   /docs/         <- DocC archive
#   /webexample/   <- Examples/WebExample WASI demo

# Cross-origin isolation for the whole origin so the WebExample iframe
# can use SharedArrayBuffer-backed stdin without a service-worker shim.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin

# HTML pages: revalidate every request so content updates appear immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Astro hashes asset filenames, so they're safe to cache aggressively.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# DocC archive assets are content-addressed at build time.
/docs/css/*
  Cache-Control: public, max-age=31536000, immutable

/docs/js/*
  Cache-Control: public, max-age=31536000, immutable

/docs/images/*
  Cache-Control: public, max-age=31536000, immutable

/docs/data/*
  Cache-Control: public, max-age=3600

# WebExample wasm bundle is Brotli-compressed by `bun run build:wasm`
# to stay under Pages' 25 MiB per-file limit; advertise the encoding here.
/webexample/TerminalApp/dist/assets/app.wasm
  Cache-Control: public, max-age=31536000, immutable, no-transform
  Content-Type: application/wasm
  Content-Encoding: br

/webexample/assets/*
  Cache-Control: public, max-age=31536000, immutable
